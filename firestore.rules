rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla: Los usuarios solo pueden leer y escribir en su propio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Regla: Los usuarios solo pueden ver y modificar sus propias tareas
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}